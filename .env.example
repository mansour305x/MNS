# Telegram token from @BotFather. Never commit a real token.
BOT_TOKEN=123456789:REPLACE_WITH_YOUR_TELEGRAM_BOT_TOKEN

# Comma-separated numeric Telegram user IDs who can access full admin features.
# Get your ID from @userinfobot or similar.
ADMIN_IDS=123456789

# Local default. For production, use Neon/Supabase/managed PostgreSQL:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=sqlite:///bot_data.sqlite3

# Health server used by free hosting platforms.
APP_HOST=0.0.0.0
APP_PORT=8080
PORT=8080

ENVIRONMENT=development
LOG_LEVEL=INFO

# Anti-spam limits per user.
RATE_LIMIT_WINDOW_SECONDS=5
RATE_LIMIT_MAX_ACTIONS=8

# Broadcast safety controls.
BROADCAST_CHUNK_SIZE=25
BROADCAST_DELAY_SECONDS=1.0

BACKUP_DIR=backups
